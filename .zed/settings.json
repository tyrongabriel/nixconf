// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
  "file_types": {
    "Shell Script": [".envrc"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/clusterconfig/*",
  ],

  "lsp": {
    "nixd": {
      "settings": {
        "nixpkgs": {
          "expr": "import (builtins.getFlake ./.).inputs.nixpkgs { }   ",
        },
        "options": {
          "nix": {
            "expr": "((myFlake: builtins.foldl' (acc: cfgName: acc // (myFlake.colmenaHive.nodes.\"${cfgName}\".options or {})) {} (builtins.attrNames myFlake.colmenaHive.nodes)) (builtins.getFlake (toString ./.)))",
          },
          "home-manager": {
            "expr": "((myFlake: builtins.foldl' (acc: cfgName: acc // (myFlake.colmenaHive.nodes.\"${cfgName}\".options.home-manager.users.type.getSubOptions [])) {} (builtins.attrNames myFlake.colmenaHive.nodes)) (builtins.getFlake (toString ./.)))",
          },
        },
      },
    },
  },
}

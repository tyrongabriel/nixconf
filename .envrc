use flake

# Check if Bitwarden is unlocked by looking for the session token
if [ -n "$BW_SESSION" ]; then
  # Fetch the password and export it
  export TF_VAR_state_passphrase=$(bw get password "OpenTofu Infra State Key")
  echo "✅ OpenTofu state passphrase loaded from Bitwarden"
else
  echo "⚠️ Bitwarden is locked (BW_SESSION is not set)."
  echo "👉 Run 'export BW_SESSION=\$(bw unlock --raw)' and then 'direnv allow' or 'direnv reload'."
fi
